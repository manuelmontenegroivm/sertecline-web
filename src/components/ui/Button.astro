---
/**
 * Botón de marca — primitiva del Design System (EPIC 3.4).
 * Elemento <button> semántico únicamente: para un enlace con esta misma
 * apariencia usar <ButtonLink> (EPIC 3.10) — nunca un <Button> con href
 * fingiendo ser enlace. Variantes/tamaños viven en ./buttonStyles.ts,
 * compartido con <ButtonLink>; lo que sigue local a este archivo (estado
 * disabled, tamaño de ícono) es exclusivo de <button>.
 *
 * Iconos: pasar SVG a los slots `icon-leading` / `icon-trailing` con
 * `aria-hidden="true"` (el nombre accesible del botón lo da el slot por
 * defecto). El tamaño recomendado del icono está expuesto en la custom
 * property `--btn-icon-size` del propio <button>, ej. `width="var(--btn-icon-size)"`.
 *
 * El foco visible NO se redefine aquí: hereda la regla global
 * `:focus-visible` de src/styles/brand.css (evita duplicar el token de foco).
 *
 * `loading` es puramente prop-driven (SSR, sin JS propio). Un consumidor que
 * necesite alternarlo en cliente (ej. envío de formulario) lo controla desde
 * el island que maneja ese estado.
 */
import VisuallyHidden from './VisuallyHidden.astro';
import {
  BUTTON_BASE_CLASSES,
  BUTTON_VARIANT_CLASSES,
  BUTTON_SIZE_CLASSES,
  type ButtonVariant,
  type ButtonSize,
} from './buttonStyles';

export type { ButtonVariant, ButtonSize };

interface Props extends Omit<astroHTML.JSX.ButtonHTMLAttributes, 'type'> {
  variant?: ButtonVariant;
  size?: ButtonSize;
  /** Estado de carga: deshabilita el botón, muestra spinner y aria-busy. @default false */
  loading?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  size = 'md',
  loading = false,
  disabled = false,
  type = 'button',
  class: className,
  ...rest
} = Astro.props as Props;

const ICON_SIZE: Record<ButtonSize, string> = {
  sm: 'var(--icon-sm)',
  md: 'var(--icon-md)',
  lg: 'var(--icon-lg)',
};

const isDisabled = disabled || loading;

const classes = [
  BUTTON_BASE_CLASSES,
  'disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-[var(--opacity-disabled)]',
  BUTTON_VARIANT_CLASSES[variant],
  BUTTON_SIZE_CLASSES[size],
  className,
]
  .filter(Boolean)
  .join(' ');
---

<button
  type={type}
  class={classes}
  style={`--btn-icon-size:${ICON_SIZE[size]}`}
  disabled={isDisabled}
  aria-busy={loading ? 'true' : undefined}
  {...rest}
>
  {
    loading ? (
      <span
        class="size-[var(--btn-icon-size)] animate-spin rounded-full border-2 border-current border-t-transparent"
        aria-hidden="true"
      />
    ) : (
      <slot name="icon-leading" />
    )
  }
  <slot />
  {!loading && <slot name="icon-trailing" />}
  {loading && <VisuallyHidden>Cargando</VisuallyHidden>}
</button>
