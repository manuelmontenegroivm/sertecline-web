---
/**
 * Sección "Preguntas frecuentes" (EPIC 3.9). Vive debajo de "Cobertura" en
 * home. Lista las preguntas de src/data/faqs.ts (única fuente — mismo shape
 * {question, answer} que usará el futuro FAQPage JSON-LD) usando FaqItem
 * (`<details>/<summary>` nativo, sin JS). No confundir con el campo `faqs`
 * de la content collection `services` (content.config.ts): ese es para
 * preguntas específicas de cada ficha de servicio futura, un dataset
 * distinto que esta sección no consulta.
 * `scroll-mt-24` compensa el header sticky al navegar por ancla
 * (`/#preguntas-frecuentes`) — mismo tratamiento que las demás secciones de
 * home. Deliberadamente fuera de `primaryNav` (src/data/navigation.ts) por
 * ahora: decisión del proyecto de no sobrecargar la navegación, en especial
 * en móvil. El `id` queda estable para enlaces contextuales futuros (ej.
 * desde una página de servicio o desde el footer).
 */
import Section from '../layout/Section.astro';
import Badge from '../ui/Badge.astro';
import FaqItem from '../faq/FaqItem.astro';
import { faqs } from '../../data/faqs';
import { faqSectionContent } from '../../data/faqSection';
---

<Section
  as="section"
  id="preguntas-frecuentes"
  background="paper"
  spacing="lg"
  class="scroll-mt-24"
>
  <div class="flex flex-col gap-8">
    <div class="max-w-prose">
      <Badge>{faqSectionContent.eyebrow}</Badge>
      <h2 class="text-ink mt-4 text-3xl font-black tracking-tight md:text-4xl">
        {faqSectionContent.heading}
      </h2>
      <p class="text-ink-2 mt-4 text-lg">{faqSectionContent.intro}</p>
    </div>

    <div class="max-w-prose">
      {faqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
    </div>

    <p class="text-ink-2 text-sm">{faqSectionContent.note}</p>
  </div>
</Section>
