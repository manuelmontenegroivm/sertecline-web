---
/**
 * Header sticky del sitio. Blur + z-index usan los tokens ya previstos para
 * esto en tokens.css (`--blur-md` "nav sticky", `--z-sticky` "nav").
 */
import Container from './Container.astro';
import Navbar from './Navbar.astro';
import Logo from '../ui/Logo.astro';
---

<header
  class="border-hairline bg-paper/80 sticky top-0 z-[var(--z-sticky)] border-b backdrop-blur-[var(--blur-md)]"
>
  <Container>
    <div class="relative flex items-center justify-between py-4">
      <a href="/" aria-label="Sertecline — inicio" class="shrink-0">
        <Logo variant="primary" class="h-8 w-auto" />
      </a>
      <Navbar />
    </div>
  </Container>
</header>
