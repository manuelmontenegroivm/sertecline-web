{
  "$meta": {
    "name": "SERTECLine Design Tokens",
    "checkpoint": "3.2",
    "derivedFrom": "Dirección Creativa (Epic 2), congelada",
    "target": "Astro 7 + React + Tailwind CSS v4 + TypeScript",
    "contrastVerified": "WCAG 2.1 sobre #F4F1EB (papel) y #141210 (stage)"
  },
  "color": {
    "brand": {
      "value": "#4C9E5D",
      "role": "relleno/gráfico",
      "onPaper": "2.93:1",
      "note": "NO usar para texto ni fondo de CTA con texto pequeño"
    },
    "brandInk": {
      "value": "#2E6B43",
      "role": "acento UI · enlaces · CTA · foco",
      "onPaper": "5.64:1 AA",
      "whiteOn": "6.36:1 AA"
    },
    "brandOnDark": { "value": "#8FC79E", "role": "acento sobre stage", "onStage": "9.64:1 AAA" },
    "taupe": {
      "value": "#8C8377",
      "role": "texto grande/UI",
      "onPaper": "3.31:1",
      "note": "no usar para cuerpo <19px"
    },
    "paper": { "value": "#F4F1EB", "role": "fondo app" },
    "paper2": { "value": "#FCFBF7", "role": "tarjetas/elevado" },
    "stage": { "value": "#141210", "role": "secciones oscuras · evidence stage" },
    "ink": { "value": "#1A1712", "role": "texto principal", "onPaper": "15.85:1 AAA" },
    "ink2": { "value": "#57524A", "role": "texto secundario", "onPaper": "6.87:1 AA" },
    "ink3": { "value": "#8C8377", "role": "terciario/caption", "onPaper": "3.31:1" },
    "inkOnDark": { "value": "#F4F1EB", "onStage": "16.58:1 AAA" },
    "ink2OnDark": { "value": "#A39C8E", "onStage": "6.85:1 AA" },
    "hairline": { "value": "#DED8CC", "role": "borde 1px por defecto" },
    "hairlineStrong": { "value": "#C9C2B4", "role": "guías/divisores" },
    "success": { "value": "#2E6B43", "note": "== brandInk, intencional" },
    "warning": { "value": "#B5761E" },
    "danger": { "value": "#B02A1F", "onPaper": "5.83:1 AA", "whiteOn": "6.57:1 AA" },
    "info": { "value": "#2E5E8A", "note": "uso excepcional" },
    "successBg": { "value": "#EAF4E8" },
    "warningBg": { "value": "#F6EEDD" },
    "dangerBg": { "value": "#F6E2DF" },
    "ring": { "value": "#2E6B43", "role": "anillo de foco 2px offset 2px" }
  },
  "font": {
    "sans": "'Archivo', system-ui, -apple-system, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace"
  },
  "fontSize": {
    "_ratio": 1.25,
    "_base": "16px",
    "2xs": { "px": 10, "lineHeight": 1.4, "use": "micro-labels mono" },
    "xs": { "px": 13, "lineHeight": 1.5, "use": "caption" },
    "sm": { "px": 14, "lineHeight": 1.5, "use": "UI densa (excepción)" },
    "base": { "px": 16, "lineHeight": 1.6, "use": "cuerpo" },
    "lg": { "px": 20, "lineHeight": 1.4, "use": "cuerpo grande / h4" },
    "xl": { "px": 25, "lineHeight": 1.2, "use": "h3" },
    "2xl": { "px": 31, "lineHeight": 1.1, "use": "h2" },
    "3xl": { "px": 39, "lineHeight": 1.05, "use": "h1" },
    "4xl": { "px": 49, "lineHeight": 1.0, "use": "display-sm" },
    "5xl": { "px": 61, "lineHeight": 0.98, "use": "display" },
    "6xl": { "px": 76, "lineHeight": 0.94, "use": "hero display" }
  },
  "fontWeight": {
    "normal": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700,
    "extrabold": 800,
    "black": 900
  },
  "tracking": { "tighter": "-0.03em", "tight": "-0.02em", "normal": "0em", "overline": "0.2em" },
  "spacing": {
    "base": "4px",
    "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96, 128],
    "rule": "múltiplos de 4; sin valores arbitrarios"
  },
  "radius": { "xs": 6, "sm": 8, "md": 12, "lg": 16, "xl": 20, "2xl": 24, "full": 9999 },
  "shadow": {
    "xs": "0 1px 2px rgba(26,23,18,0.04)",
    "sm": "0 1px 3px rgba(26,23,18,0.06)",
    "md": "0 8px 24px rgba(26,23,18,0.10)",
    "lg": "0 20px 50px rgba(26,23,18,0.12)",
    "insetHighlight": "inset 0 1px 0 rgba(244,241,235,0.05)",
    "rule": "cálidas, nunca negro puro; la separación primaria son hairlines"
  },
  "elevation": {
    "e0": "paper · base",
    "e1": "paper-2 + hairline · tarjeta (sin sombra)",
    "e2": "paper-2 + shadow-xs · elevado (input/hover)",
    "e3": "paper-2 + shadow-lg · flotante (drawer/modal/hero image)"
  },
  "duration": { "fast": "120ms", "base": "180ms", "slow": "260ms", "slower": "400ms" },
  "easing": {
    "out": "cubic-bezier(0.2,0.8,0.2,1)",
    "inOut": "cubic-bezier(0.4,0,0.2,1)",
    "in": "cubic-bezier(0.4,0,1,1)",
    "rule": "sin rebote ni elástico"
  },
  "motion": { "hoverLift": "translateY(-1px)", "press": "scale(0.98)" },
  "breakpoint": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1536,
    "strategy": "mobile-first"
  },
  "container": { "narrow": "720px", "prose": "65ch", "content": "1200px", "wide": "1360px" },
  "grid": { "columns": 12, "gutter": 24, "gutterMobile": 16 },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "sticky": 50,
    "dropdown": 100,
    "overlay": 200,
    "drawer": 300,
    "modal": 400,
    "toast": 500,
    "tooltip": 600
  },
  "opacity": {
    "disabled": 0.4,
    "muted": 0.6,
    "scrim": 0.5,
    "hairlineDark": 0.14,
    "note": "nunca reducir la opacidad del logo"
  },
  "blur": { "sm": "8px", "md": "10px", "lg": "16px", "rule": "solo chrome sobre contenido" },
  "borderWidth": { "hairline": "1px", "emphasis": "2px", "accent": "4px" },
  "iconSize": {
    "xs": 14,
    "sm": 16,
    "md": 18,
    "lg": 20,
    "xl": 22,
    "2xl": 24,
    "stroke": "1.75px",
    "set": "Lucide"
  }
}
