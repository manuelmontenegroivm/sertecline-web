---
/**
 * Layout base del sitio: documento HTML, metadata SEO/OG/Twitter, favicons
 * y activación del design system. No incluye Header/Footer todavía
 * (EPIC 3.3 — Brand Foundation Implementation).
 */
import '../styles/global.css';
import { siteConfig } from '../config/site';
import { seoDefaults } from '../config/seo';

interface Props {
  /** Título de página (sin el sufijo " | Sertecline", se agrega automáticamente). */
  title?: string;
  description?: string;
  /** Ruta absoluta o relativa a `siteConfig.url` de la imagen para OG/Twitter. */
  image?: string;
  /** URL canónica completa. Por defecto se deriva de `Astro.url` + `astro.config.mjs#site`. */
  canonical?: string;
  /** Excluye la página de indexación (borradores, páginas utilitarias). @default false */
  noindex?: boolean;
}

const {
  title,
  description = seoDefaults.defaultDescription,
  image = seoDefaults.defaultImage,
  canonical = new URL(Astro.url.pathname, Astro.site ?? siteConfig.url).toString(),
  noindex = false,
} = Astro.props;

const pageTitle = title ? seoDefaults.titleTemplate.replace('%s', title) : seoDefaults.defaultTitle;
const ogImage = new URL(image, siteConfig.url).toString();
const ogLocale = seoDefaults.locale.replace('-', '_');
---

<!doctype html>
<html lang={siteConfig.defaultLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicons & PWA — public/brand/ (EPIC 3.1 Brand Asset System) -->
    <link rel="icon" type="image/svg+xml" href="/brand/favicon/favicon.svg" />
    <link rel="icon" href="/brand/favicon/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/brand/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/brand/site.webmanifest" />
    <meta name="theme-color" content={siteConfig.themeColor} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Tipografía de marca: Archivo + JetBrains Mono (ver src/config/design/tokens.json#font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
